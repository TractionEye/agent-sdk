{
  "name": "@tractioneye/agent-sdk",
  "version": "0.1.0",
  "description": "TractionEye wrapper SDK for trading agents",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "scripts"
  ],
  "scripts": {
    "prepare": "tsup src/index.ts --format esm,cjs --dts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts",
    "postinstall": "node scripts/setup-daemon.cjs",
    "daemon": "npx tsx scripts/agent-daemon.ts",
    "daemon:start": "pm2 start npx --name tractioneye -- tsx scripts/agent-daemon.ts",
    "daemon:stop": "pm2 stop tractioneye",
    "daemon:status": "pm2 status tractioneye"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
